# Bỏ qua các tệp không cần thiết (ZaloMulti GitIgnore)

# Dữ liệu cá nhân & cấu hình riêng máy
settings.json
custom_path.txt
desktop_profiles.json
profiles_config.json
donate_status.json

# Thư mục chứa file .bat sinh tự động
Shortcuts/

# Ghi chú nội bộ
lessons_learned.md

# Tệp tạm của PowerShell
*.log
*.tmp

# Cấu hình trình chỉnh sửa code (IDE)
.vscode/
.gemini/
.idea/

# Tệp rác của hệ điều hành
Thumbs.db
Desktop.ini

# Build artifacts & bản phát hành cũ (đã chuyển sang GitHub Releases)
*.exe
update.zip
update/

# Tệp sao lưu (Backup)
*.zlp

# Thư mục tạm
temp/
