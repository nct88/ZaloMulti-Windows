<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý ZalỏMulti" Height="700" Width="1000"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="__FONT_PATH__">
    <Window.Resources>
        <!-- Hệ thống màu sắc macOS-inspired (Mặc định Tối) -->
        <SolidColorBrush x:Key="BgDark" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#2C2C2E"/>
        <SolidColorBrush x:Key="BgCard" Color="#3A3A3C"/>
        <SolidColorBrush x:Key="BgToggle" Color="#48484A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#38383A"/>
        <SolidColorBrush x:Key="TextMain" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSec" Color="#98989D"/>
        
        
        <!-- Nút đóng tất cả -->
        <SolidColorBrush x:Key="KillAllBtnBg" Color="#007AFF"/>
        <SolidColorBrush x:Key="KillAllBtnFg" Color="#FFFFFF"/>
        
        <!-- Nút mạng xã hội -->
        <SolidColorBrush x:Key="SocialBtnBg" Color="#3A3A3C"/>
        <Color x:Key="SocialShadowColor">#40000000</Color>
        
        <SolidColorBrush x:Key="AccentBlue" Color="#007AFF"/>
        <SolidColorBrush x:Key="AccentGradBrush" Color="#007AFF"/>
        <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>
 
        <!-- Sửa lỗi Font toàn cục -->
        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="__FONT_PATH__"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="__FONT_PATH__"/>
        </Style>

        <!-- Nút hành động trong thẻ -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="{DynamicResource BgToggle}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút mạng xã hội - nổi 3D với đổ bóng -->
        <Style x:Key="SocialBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SocialBorder" Background="{DynamicResource SocialBtnBg}" CornerRadius="18" 
                                BorderBrush="Transparent" BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource SocialShadowColor}" BlurRadius="6" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter Margin="8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SocialBorder" Property="Background" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SocialBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{DynamicResource SocialShadowColor}" BlurRadius="2" ShadowDepth="1" Direction="270" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút đóng tất cả Zalo -->
        <Style x:Key="KillAllBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource KillAllBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource KillAllBtnFg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="KillBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KillBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KillBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ô nhập liệu -->
        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Nút chính nổi bật (Thêm tài khoản) -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentGradBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AccentBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AccentBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="AccentBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Nút tròn chọn màu -->
        <Style x:Key="ColorCircle" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource BgDark}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Thanh bên trái (Sidebar) -->
            <Border Grid.Column="0" Background="{DynamicResource BgSidebar}" CornerRadius="12,0,0,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="24">
                    <StackPanel>
                        <!-- Logo & tên ứng dụng -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                            <Image Name="ImgLogo" Width="40" Height="40" Stretch="Uniform"/>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="ZalỏMulti" FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                                <TextBlock Name="TxtVersion" Text="Đang tải..." FontSize="11" Foreground="{DynamicResource TextSec}" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nút thêm tài khoản -->
                        <Button Name="BtnAdd" Content="＋ Thêm tài khoản" Style="{StaticResource AccentBtn}" FontSize="15" Margin="0,0,0,14"/>
                        

                        <!-- Chuyển đổi chủ đề -->
                        <TextBlock Text="Giao diện" Foreground="{DynamicResource TextSec}" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <Border Background="{DynamicResource BgToggle}" CornerRadius="10" Padding="3" HorizontalAlignment="Center">
                            <Grid Width="80" Height="30">
                                <!-- Thanh trượt highlight -->
                                <Border Name="ThemeIndicator" Background="{DynamicResource AccentBlue}" Width="40" Height="30" CornerRadius="8" HorizontalAlignment="Left">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0" />
                                    </Border.RenderTransform>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Name="BtnLight" Content="☀️" Width="40" Height="30" Style="{StaticResource ActionBtn}" Background="Transparent"/>
                                    <Button Name="BtnDark" Content="🌙" Width="40" Height="30" Style="{StaticResource ActionBtn}" Background="Transparent"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Phần dưới cùng -->
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Button Name="BtnFB" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgFB" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnTG" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgTG" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnGH" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgGH" Stretch="Uniform"/>
                            </Button>
                            <Button Name="BtnWS" Style="{StaticResource SocialBtn}">
                                <Image Name="ImgWS" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                        <Button Name="BtnKillAll" Content="✕  Đóng tất cả Zalo" Style="{StaticResource KillAllBtn}" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Nội dung chính -->
            <Grid Grid.Column="1" Margin="32,28,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="Tài khoản đang hoạt động" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="Quản lý các tài khoản Zalo của bạn một cách dễ dàng." FontSize="13" Foreground="{DynamicResource TextSec}" Margin="0,6,0,0"/>
                    </StackPanel>
                    
                    <!-- Nút điều khiển cửa sổ macOS -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,0,0">
                        <Button Name="BtnMin" Width="13" Height="13" Margin="0,0,8,0" Cursor="Hand" ToolTip="Thu nhỏ">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="MinBorder" Background="#FFBD2E" CornerRadius="6.5" BorderBrush="#E0A41E" BorderThickness="0.5"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="MinBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Name="BtnMax" Width="13" Height="13" Margin="0,0,8,0" Cursor="Hand" ToolTip="Phóng to">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="MaxBorder" Background="#27C93F" CornerRadius="6.5" BorderBrush="#1DAD2B" BorderThickness="0.5"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="MaxBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Name="BtnClose" Width="13" Height="13" Cursor="Hand" ToolTip="Đóng ứng dụng">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="#FF5F56" CornerRadius="6.5" BorderBrush="#E04840" BorderThickness="0.5"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer Name="MainScroll" VerticalScrollBarVisibility="Hidden">
                        <WrapPanel Name="InstanceGrid" ItemWidth="330">
                            <!-- Nội dung động sẽ xuất hiện ở đây -->
                        </WrapPanel>
                    </ScrollViewer>
                    
                    <Button Name="BtnToTop" Content="↑" Style="{StaticResource ActionBtn}" 
                            Background="{DynamicResource BgToggle}" Width="38" Height="38" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Margin="0,0,16,16" Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
<!-- Bản quyền thuộc về truong.it - Tác giả: truong.it -->
